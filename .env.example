# ─────────────────────────────────────────────────
# 7301N – Web-to-PDF API  |  Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to `.env` and adjust values as needed.
#   cp .env.example .env

# ── Server ────────────────────────────────────────
NODE_ENV=development
PORT=7301
# Host to bind the server to ("0.0.0.0" for all interfaces)
HOST=0.0.0.0

# ── Security ─────────────────────────────────────
# API key required for /pdf/* endpoints. Leave empty to disable auth.
API_KEY=
# Comma-separated list of allowed CORS origins. Use * to allow all.
CORS_ORIGINS=*

# ── Rate Limiting ────────────────────────────────
# Max requests per window per IP
RATE_LIMIT_MAX=20
# Window duration in minutes
RATE_LIMIT_WINDOW_MIN=1

# ── Puppeteer / Browser ─────────────────────────
# Viewport dimensions for the headless browser
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=2080
# Max time (ms) to wait for a page to load
PAGE_LOAD_TIMEOUT=30000
# Max time (ms) to wait when creating a new browser tab
PAGE_CREATE_TIMEOUT=10000
# Delay (ms) after page load before generating PDF (for lazy content)
POST_LOAD_DELAY=2000
# Run browser in headless mode
HEADLESS=true

# ── Express ──────────────────────────────────────
# Max JSON request body size
JSON_BODY_LIMIT=10mb
