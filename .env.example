# ─────────────────────────────────────────────────
# 7301N – Web-to-PDF API  |  Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to `.env` and adjust values as needed.
#   cp .env.example .env


# ┌─────────────────────────────────────────────────┐
# │  1. Server                                       │
# └─────────────────────────────────────────────────┘

NODE_ENV=development            # "development" | "production"
PORT=7301                       # Port the server listens on
HOST=0.0.0.0                   # Bind address ("0.0.0.0" = all interfaces)
JSON_BODY_LIMIT=10mb           # Max JSON request body size


# ┌─────────────────────────────────────────────────┐
# │  2. Security & Access Control                    │
# └─────────────────────────────────────────────────┘

API_KEY=                        # API key for /pdf/* endpoints (empty = auth disabled)
CORS_ORIGINS=*                 # Comma-separated allowed origins (* = allow all)
RATE_LIMIT_MAX=20              # Max requests per window per IP
RATE_LIMIT_WINDOW_MIN=1        # Rate-limit window duration (minutes)


# ┌─────────────────────────────────────────────────┐
# │  3. Browser – Viewport                           │
# └─────────────────────────────────────────────────┘

VIEWPORT_WIDTH=1920            # Headless browser viewport width (px)
VIEWPORT_HEIGHT=2080           # Headless browser viewport height (px)
HEADLESS=true                  # Run browser in headless mode


# ┌─────────────────────────────────────────────────┐
# │  4. Browser – Timing                             │
# └─────────────────────────────────────────────────┘

PAGE_LOAD_TIMEOUT=30000        # Max wait for page load (ms)
PAGE_CREATE_TIMEOUT=10000      # Max wait for new browser tab (ms)
POST_LOAD_DELAY=2000           # Delay after load before PDF generation (ms)


# ┌─────────────────────────────────────────────────┐
# │  5. Browser – Executable                         │
# └─────────────────────────────────────────────────┘

# Custom Chromium path (auto-set in Docker; leave empty for local dev)
# PUPPETEER_EXECUTABLE_PATH=
